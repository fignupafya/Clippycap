# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.uv/
uv.lock        # (remove this line if you decide to commit the lockfile)

# --- type / lint / test caches ---
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# --- frontend (web/) ---
web/node_modules/
web/dist/
web/.svelte-kit/
*.tsbuildinfo

# --- packaging ---
packaging/build/
packaging/dist/
packaging/*.spec.bak
# bundled native tools fetched by packaging/get_ffmpeg.* (not committed)
packaging/bin/

# --- app runtime data (never committed) ---
# The real data dir lives under the OS app-data folder, but if anyone points
# data_dir at the repo for testing, keep it out of git:
data/
*.sqlite
*.sqlite-*

# --- editors / OS ---
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
desktop.ini

# bundled ffmpeg / ffprobe -- fetched or copied locally, never committed
/bin/
packaging/bin/

# --- packaged executables (output of packaging/build.ps1, placed in the repo root; never committed) ---
/Clippycap-Portable.exe
/Clippycap-Setup.exe

# --- tests + 3rd-party plugins ---
# Tests live locally for development; they're not part of the shipped product or this repo. Plugins
# is the in-tree placeholder for third-party plugin packages -- the runtime framework
# (src/clippycap/plugins_runtime/) handles a missing directory cleanly, so we don't ship the
# empty folder. Both stay ignored so a developer can keep them locally without polluting commits.
/tests/
/plugins/
